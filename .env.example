# NewVideoTranslate — Credential Template
# Copy this file to your Google Drive: MyDrive/video-translate/.env
# 将此文件复制到 Google Drive: 我的云端硬盘/video-translate/.env

# Required: ngrok auth token (get from https://dashboard.ngrok.com/get-started/your-authtoken)
# 必需：ngrok 认证 token（需绑定信用卡才能使用 TCP 隧道）
NGROK_TOKEN=your_ngrok_token_here

# Required: SSH password for Colab root access
# 必需：Colab SSH 登录密码（自定义）
SSH_PASSWORD=your_password_here

# Optional: HuggingFace token (for speaker diarization)
# 可选：HuggingFace token（用于说话人分离，需接受 pyannote 许可）
# HF_TOKEN=hf_your_token_here
